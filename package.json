  "bin": {
    "sql-query-parser": "node ./src/cli.js"
  },
  "keywords": [],
  "author": "Himanshi",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "csv-parser": "^3.0.0",
    "eslint": "^9.29.0",
    "eslint-plugin-vue": "^10.2.0",
    "globals": "^16.2.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.34.1"
  },
  "dependencies": {
    "chalk": "^4.1.2",
