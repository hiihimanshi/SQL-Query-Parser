# Application Configuration

# Environment: development, production, test
NODE_ENV=development

# Application Settings
APP_NAME=Query-Master
APP_VERSION=1.0.0
DATA_DIR=./data
LOGS_DIR=./logs

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=5
LOG_CONSOLE=true
LOG_FILE_ENABLED=true

# Query Execution
QUERY_MAX_DURATION=30000
QUERY_MAX_RESULT_SIZE=1000000
QUERY_CACHE=true
QUERY_CACHE_TTL=3600000

# Security
SECURITY_VALIDATION=true
SECURITY_SANITIZATION=true
SECURITY_MAX_QUERY_LENGTH=50000
SECURITY_ALLOW_TRAVERSAL=false

# CSV
CSV_ENCODING=utf8
CSV_DELIMITER=,
CSV_QUOTE="

# Debug
DEBUG=false
VERBOSE=false

# Required environment variables (comma-separated, optional)
# REQUIRED_ENV_VARS=DATABASE_URL,API_KEY
